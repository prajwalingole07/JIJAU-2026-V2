GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Firebase (required for LIVE, cross-device data sync)
# ---------------------------------------------------------------------------
# Without these keys the app runs in "local mode": data is saved only to the
# browser's local storage on that one device/phone, so changes will NOT show
# up when you log in from another phone or browser.
#
# To enable live sync:
# 1. Go to https://console.firebase.google.com and open (or create) your project.
#    Project ID for this app is already reserved as: studio-8965989657-abdd6
# 2. Project Settings -> General -> "Your apps" -> Add a Web App (</>) if you
#    haven't already, then copy the firebaseConfig values shown there.
# 3. Paste them below, rename this file to ".env.local", and restart the app.
# 4. In Firebase Console -> Build -> Firestore Database, click "Create
#    database" (production mode is fine) so the app has somewhere to write to.
# 5. Set Firestore security rules so only signed-in members of your school can
#    read/write (ask your developer, or start permissive for testing only).
#
# Once these are filled in, every phone/browser that logs in will see the
# same live data, and updates from one device appear instantly on the others.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=studio-8965989657-abdd6.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-8965989657-abdd6
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studio-8965989657-abdd6.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
